# =============================================================================
# Template de variaveis de ambiente para Amazonas Recicla (web).
# Copie este arquivo para .env.local e preencha com SEUS valores.
# NUNCA commita .env.local — somente este .env.example com placeholders.
# Ver SECURITY.md para boundary publico vs secreto.
# =============================================================================

# --- Supabase ---
# Publicas (vao para o bundle do client). Seguranca real vem da Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole-aqui-a-anon-key-do-dashboard

# Secreta. NUNCA importar em arquivo com "use client". Bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY=cole-aqui-a-service-role-key-do-dashboard

# --- Banco ---
# Use a Transaction Pooler (porta 6543) com pgbouncer=true.
# Pegue em Supabase Dashboard -> Settings -> Database -> Connection string -> Transaction.
DATABASE_URL=postgresql://postgres.SEU_PROJETO:SENHA_DB@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# --- Hosts ---
# Local em dev, dominio Vercel em producao.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Chaves de bin (firmware ESP32) ---
# Configurar por bin, no painel admin. Nao precisa aqui em desenvolvimento local
# a menos que voce esteja testando o fluxo ESP32 → backend.
# BIN_API_KEY_BIN_MNS_001=
