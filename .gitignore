# =============================================================================
# .gitignore — Amazonas Recicla
# Repositório PÚBLICO: tudo abaixo é deliberadamente bloqueado para evitar
# vazamento de segredos, dados sensíveis ou ruído.
# =============================================================================

# --- Markdown ---
# Bloqueia todos os .md por padrão. Único permitido é README.md em qualquer
# nível (raiz, web/, firmware/, shared/, etc).
*.md
!README.md
!**/README.md

# --- Específicos do projeto ---
CLAUDE.md
AGENTS.md
GEMINI.md
archives/
docs/

# --- Variáveis de ambiente e segredos ---
# NUNCA versionar arquivos .env reais.
.env
.env.*
!.env.example
!.env.*.example

# --- Credenciais e chaves ---
*.pem
*.key
*.crt
*.cer
*.csr
*.pfx
*.p12
id_rsa*
id_ed25519*
id_ecdsa*
*.kdbx
secrets/
private/
.secrets/
.credentials/

# --- Provedores de cloud (caches de auth local) ---
.aws/
.gcloud/
.azure/
.kube/
.terraform/
.terraformrc
terraform.tfstate*

# --- Vercel / Deploy ---
.vercel/
.vercel
.netlify/
.firebase/
.firebaserc

# --- Backups de banco e dumps ---
# Bloqueia SQL solto na raiz/qualquer lugar (dumps acidentais),
# mas permite migrations e policies versionadas dentro de drizzle/.
*.sql
!web/drizzle/**/*.sql
*.sql.gz
*.dump
*.bak
dump.rdb
*.sqlite
*.sqlite3
*.db

# --- Sistema operacional ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride

# --- Editores / IDEs / Ferramentas de AI ---
.vscode/
.idea/
*.swp
*.swo
*~
.history/
.cursor/
.codeium/
.aider*
.continue/

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Dependências (Node / JS) ---
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/

# --- Build / Dist ---
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
.vite/
coverage/
*.tsbuildinfo

# --- Python (caso scripts auxiliares) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/

# --- Arduino / PlatformIO (firmware) ---
.pio/
.pioenvs/
.piolibdeps/
*.hex
*.bin
*.elf
# Segredos do firmware (bin API key, etc) — nunca commitar.
firmware/**/secrets.h
!firmware/**/secrets.h.example

# --- Misc ---
*.tmp
*.orig
*.local
